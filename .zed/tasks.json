[
  {
    "label": "Claude Code",
    "command": "claude --dangerously-skip-permissions",
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": true,
    "reveal": "always",
    "hide": "never",
    "show_summary": false,
    "show_command": false
  },
  {
    "label": "Build",
    "command": "pnpm run build",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "Typecheck",
    "command": "pnpm run typecheck",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "Check (Lint + Format)",
    "command": "pnpm run check:write",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "Test",
    "command": "pnpm run test",
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never"
  }
]
