#!/bin/sh
# Test stub for atvremote: records its argv, optionally fails or stalls.
echo "atvremote $@" >> "${STUB_LOG:?STUB_LOG not set}"
case "${ATV_STUB_MODE:-ok}" in
  fail)
    echo "pyatv: something went wrong" >&2
    exit 1
    ;;
  slow)
    sleep 0.4
    ;;
  fail_deeplink)
    case "$@" in
      *launch_app=https*)
        echo "pyatv: app launch failed" >&2
        exit 1
        ;;
    esac
    ;;
esac
exit 0
